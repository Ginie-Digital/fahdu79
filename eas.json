{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "cache": {},
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "cache": {},
      "android": {
        "buildType": "apk"
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "cache": {},
      "android": {
        "buildType": "apk"
      },
      "env": {
        "REACT_NATIVE_ARCHITECTURES": "armeabi-v7a,arm64-v8a,x86,x86_64"
      }
    },
    "staging_store": {
      "distribution": "store",
      "channel": "staging",
      "cache": {},
      "env": {
        "REACT_NATIVE_ARCHITECTURES": "armeabi-v7a,arm64-v8a,x86,x86_64"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "cache": {},
      "env": {
        "REACT_NATIVE_ARCHITECTURES": "armeabi-v7a,arm64-v8a,x86,x86_64"
      }
    }
  },
  "submit": {
    "staging_store": {
      "android": {
        "track": "internal"
      }
    },
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
